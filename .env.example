# Copy to .env and fill in. NEVER commit real secrets — .env* is gitignored.

# AI screener — any OpenAI-compatible chat API (DeepSeek, Groq, Moonshot, OpenAI...).
# The variable names are KIMI_* for historical reasons; they point at whatever
# provider you configure below. Without a key the screener fails safe to the
# deterministic keyword fallback, so the app still runs.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.deepseek.com
KIMI_MODEL=deepseek-chat
# Keep low: the screener must return strict JSON. 0.2 is the reliable default.
KIMI_TEMPERATURE=0.2

# Supabase — powers the behaviour and anomaly agents. Without these the two
# history-driven agents contribute nothing and the engine still runs on the risk
# agent plus the AI adjudicator. Run docs/supabase_schema.sql once to create the
# table and RPC functions. The service-role key bypasses RLS and is SERVER ONLY —
# never expose it to the extension or the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
